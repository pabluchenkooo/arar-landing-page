---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHeroCanvas from '../components/PageHeroCanvas.astro';
---

<Layout title="Alquiler de Equipos IT — ARAR Representaciones" description="Alquile computadores, servidores, impresoras y más con entrega local y soporte incluido. Sin inversión de capital, períodos flexibles.">
  <Header />

  <main>
    <!-- Mini Hero -->
    <section class="hero">
      <PageHeroCanvas variant="alquiler" />
      <div class="hero__container">
        <span class="badge badge--renting animate-on-scroll">Alquiler de Equipos IT</span>
        <h1 class="hero__heading animate-on-scroll">Tecnología sin inversión de capital</h1>
        <p class="hero__subtitle animate-on-scroll">Alquile equipos de cómputo, servidores, impresoras y más con entrega local y soporte incluido.</p>
      </div>
    </section>

    <!-- Content Section -->
    <section class="content">
      <div class="content__container">
        <div class="content__grid">
          <div class="content__description animate-on-scroll">
            <h2 class="content__title">Equipos de tecnología en alquiler</h2>
            <p class="content__text">
              Desde 2003 proveemos a empresas colombianas con equipos de tecnología en modalidad de alquiler. Sin inversión de capital, con soporte técnico incluido y períodos flexibles.
            </p>
            <p class="content__text">
              Nuestro modelo le permite acceder a la tecnología más reciente sin comprometer su flujo de caja, con la tranquilidad de contar con soporte técnico dedicado.
            </p>
          </div>

          <div class="content__products animate-on-scroll">
            <h3 class="products__title">Equipos disponibles</h3>
            <div class="products__grid">
              <div class="products__card">
                <span class="products__icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                </span>
                <span class="products__label">Computadores de escritorio</span>
              </div>
              <div class="products__card">
                <span class="products__icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 8h20"/></svg>
                </span>
                <span class="products__label">Portátiles</span>
              </div>
              <div class="products__card">
                <span class="products__icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
                </span>
                <span class="products__label">Servidores</span>
              </div>
              <div class="products__card">
                <span class="products__icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 17H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v10a2 2 0 0 1-2 2h-1"/><polygon points="12 15 17 21 7 21 12 15"/></svg>
                </span>
                <span class="products__label">Proyectores</span>
              </div>
              <div class="products__card">
                <span class="products__icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                </span>
                <span class="products__label">Monitores</span>
              </div>
              <div class="products__card">
                <span class="products__icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 1a3 3 0 0 0-3 3v8a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" y1="19" x2="12" y2="23"/><line x1="8" y1="23" x2="16" y2="23"/></svg>
                </span>
                <span class="products__label">Equipos audiovisuales</span>
              </div>
              <div class="products__card">
                <span class="products__icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                </span>
                <span class="products__label">Fotocopiadoras</span>
              </div>
              <div class="products__card">
                <span class="products__icon" aria-hidden="true">
                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
                </span>
                <span class="products__label">Impresoras</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Brands Section -->
    <section class="brands">
      <div class="brands__container">
        <h2 class="brands__heading animate-on-scroll">Marcas que manejamos</h2>
        <div class="brands__grid animate-on-scroll">
          <div class="brands__item">Samsung</div>
          <div class="brands__item">Ricoh</div>
          <div class="brands__item">Epson</div>
          <div class="brands__item">Kyocera</div>
          <div class="brands__item">Apple</div>
          <div class="brands__item">Lenovo</div>
        </div>
      </div>
    </section>

    <!-- Outsourcing Section -->
    <section class="outsourcing">
      <div class="outsourcing__container">
        <div class="outsourcing__content animate-on-scroll">
          <h2 class="outsourcing__heading">Outsourcing de Impresión</h2>
          <p class="outsourcing__text">
            Ofrecemos un servicio integral de outsourcing de impresión que incluye todo lo que su empresa necesita para operar sin preocupaciones.
          </p>
          <div class="outsourcing__features">
            <div class="outsourcing__feature">
              <span class="outsourcing__feature-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="8" rx="2" ry="2"/><rect x="2" y="14" width="20" height="8" rx="2" ry="2"/><line x1="6" y1="6" x2="6.01" y2="6"/><line x1="6" y1="18" x2="6.01" y2="18"/></svg>
              </span>
              <div>
                <h4 class="outsourcing__feature-title">Hardware</h4>
                <p class="outsourcing__feature-text">Equipos de impresión de última generación instalados y configurados.</p>
              </div>
            </div>
            <div class="outsourcing__feature">
              <span class="outsourcing__feature-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
              </span>
              <div>
                <h4 class="outsourcing__feature-title">Software</h4>
                <p class="outsourcing__feature-text">Soluciones de gestión y monitoreo de impresión para control total.</p>
              </div>
            </div>
            <div class="outsourcing__feature">
              <span class="outsourcing__feature-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
              </span>
              <div>
                <h4 class="outsourcing__feature-title">Consumibles</h4>
                <p class="outsourcing__feature-text">Tóner, papel y todos los insumos necesarios, siempre disponibles.</p>
              </div>
            </div>
            <div class="outsourcing__feature">
              <span class="outsourcing__feature-icon" aria-hidden="true">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              </span>
              <div>
                <h4 class="outsourcing__feature-title">Mantenimiento</h4>
                <p class="outsourcing__feature-text">Mantenimiento preventivo y correctivo sin costo adicional.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Requirements Section -->
    <section class="requirements">
      <div class="requirements__container">
        <div class="requirements__content animate-on-scroll">
          <h2 class="requirements__heading">Documentos requeridos</h2>
          <p class="requirements__text">Para iniciar el proceso de alquiler, necesitamos los siguientes documentos:</p>
          <div class="requirements__list">
            <div class="requirements__item">
              <span class="requirements__number">1</span>
              <div>
                <h4 class="requirements__item-title">Cámara de Comercio</h4>
                <p class="requirements__item-text">Certificado vigente de existencia y representación legal.</p>
              </div>
            </div>
            <div class="requirements__item">
              <span class="requirements__number">2</span>
              <div>
                <h4 class="requirements__item-title">RUT</h4>
                <p class="requirements__item-text">Registro Único Tributario actualizado de la empresa.</p>
              </div>
            </div>
            <div class="requirements__item">
              <span class="requirements__number">3</span>
              <div>
                <h4 class="requirements__item-title">Orden de Compra</h4>
                <p class="requirements__item-text">Orden de compra o solicitud formal del servicio.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* =============================================
     HERO
     ============================================= */
  .hero {
    position: relative;
    background: linear-gradient(160deg, var(--color-neutral-950) 0%, var(--color-neutral-900) 60%, var(--color-primary-900) 100%);
    padding: 140px 0 64px;
    text-align: center;
  }

  .hero__container {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .hero .badge {
    margin-bottom: 20px;
    background-color: rgba(59, 112, 166, 0.2);
    color: #8FB2D6;
  }

  .hero__heading {
    font-size: clamp(1.8rem, 4.5vw, 2.6rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: #9EADBB;
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
  }

  /* =============================================
     CONTENT
     ============================================= */
  .content {
    padding: 96px 0;
    background-color: var(--color-bg, #ffffff);
  }

  .content__container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .content__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .content__title {
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    font-weight: 700;
    color: var(--color-dark, #1A2332);
    margin-bottom: 20px;
  }

  .content__text {
    font-size: 1rem;
    color: var(--color-text, #3D4F63);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .content__text:last-child {
    margin-bottom: 0;
  }

  .products__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-dark, #1A2332);
    margin-bottom: 24px;
  }

  .products__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .products__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 20px 12px;
    background-color: var(--color-primary-light, #EDF2F8);
    border-radius: var(--radius, 10px);
    text-align: center;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .products__card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow, 0 1px 3px rgba(15, 20, 25, 0.06));
  }

  .products__icon {
    color: var(--color-primary-900, #1B344F);
  }

  .products__label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-dark, #1A2332);
    line-height: 1.3;
  }

  /* =============================================
     BRANDS
     ============================================= */
  .brands {
    padding: 80px 0;
    background-color: var(--color-bg-alt, #F6F8FA);
  }

  .brands__container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 24px;
    text-align: center;
  }

  .brands__heading {
    font-size: clamp(1.3rem, 3vw, 1.6rem);
    font-weight: 700;
    color: var(--color-dark, #1A2332);
    margin-bottom: 40px;
  }

  .brands__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
  }

  .brands__item {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    background-color: #ffffff;
    border-radius: var(--radius, 10px);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-neutral-600, #566A80);
    box-shadow: var(--shadow-sm, 0 1px 2px rgba(15, 20, 25, 0.05));
    transition: box-shadow 0.2s ease, transform 0.2s ease;
    min-width: 140px;
  }

  .brands__item:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow, 0 1px 3px rgba(15, 20, 25, 0.06));
  }

  /* =============================================
     OUTSOURCING
     ============================================= */
  .outsourcing {
    padding: 96px 0;
    background-color: var(--color-bg, #ffffff);
  }

  .outsourcing__container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .outsourcing__heading {
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    font-weight: 700;
    color: var(--color-dark, #1A2332);
    margin-bottom: 16px;
  }

  .outsourcing__text {
    font-size: 1.05rem;
    color: var(--color-text, #3D4F63);
    line-height: 1.7;
    margin-bottom: 40px;
    max-width: 700px;
  }

  .outsourcing__features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 32px;
  }

  .outsourcing__feature {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .outsourcing__feature-icon {
    flex-shrink: 0;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary-light, #EDF2F8);
    color: var(--color-primary-900, #1B344F);
    border-radius: var(--radius-sm, 6px);
  }

  .outsourcing__feature-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-dark, #1A2332);
    margin-bottom: 4px;
  }

  .outsourcing__feature-text {
    font-size: 0.9rem;
    color: var(--color-text, #3D4F63);
    line-height: 1.5;
  }

  /* =============================================
     REQUIREMENTS
     ============================================= */
  .requirements {
    padding: 80px 0;
    background-color: var(--color-bg-alt, #F6F8FA);
  }

  .requirements__container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .requirements__heading {
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    font-weight: 700;
    color: var(--color-dark, #1A2332);
    margin-bottom: 12px;
  }

  .requirements__text {
    font-size: 1.05rem;
    color: var(--color-text, #3D4F63);
    line-height: 1.6;
    margin-bottom: 32px;
  }

  .requirements__list {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 600px;
  }

  .requirements__item {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .requirements__number {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--color-primary-900, #1B344F);
    color: #ffffff;
    font-size: 0.85rem;
    font-weight: 700;
    border-radius: 50%;
  }

  .requirements__item-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-dark, #1A2332);
    margin-bottom: 2px;
  }

  .requirements__item-text {
    font-size: 0.9rem;
    color: var(--color-text, #3D4F63);
    line-height: 1.5;
  }

  /* =============================================
     RESPONSIVE
     ============================================= */
  @media (max-width: 1024px) {
    .content__grid {
      gap: 48px;
    }

    .outsourcing__features {
      gap: 24px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 120px 0 48px;
    }

    .content {
      padding: 64px 0;
    }

    .content__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .products__grid {
      grid-template-columns: 1fr 1fr;
    }

    .brands {
      padding: 64px 0;
    }

    .outsourcing {
      padding: 64px 0;
    }

    .outsourcing__features {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    .requirements {
      padding: 64px 0;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 108px 0 40px;
    }

    .hero__heading {
      font-size: 1.6rem;
    }

    .content {
      padding: 48px 0;
    }

    .products__grid {
      grid-template-columns: 1fr 1fr;
      gap: 8px;
    }

    .brands {
      padding: 48px 0;
    }

    .brands__grid {
      gap: 12px;
    }

    .brands__item {
      min-width: auto;
      padding: 12px 20px;
      font-size: 0.9rem;
    }

    .outsourcing {
      padding: 48px 0;
    }

    .requirements {
      padding: 48px 0;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const animElements = document.querySelectorAll('.animate-on-scroll');

  animElements.forEach((el) => {
    gsap.fromTo(
      el,
      { opacity: 0, y: 30 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          once: true,
        },
      }
    );
  });
</script>
