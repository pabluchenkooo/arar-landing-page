---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import PageHeroCanvas from '../components/PageHeroCanvas.astro';
---

<Layout title="1nativoone ERP — ARAR Representaciones" description="Plataforma ERP empresarial de nueva generación construida sobre microservicios con arquitectura orientada a aspectos.">
  <Header />

  <main>
    <!-- Mini Hero -->
    <section class="hero">
      <PageHeroCanvas variant="nativoone" />
      <div class="hero__container">
        <span class="badge badge--nativoone animate-on-scroll">1nativoone ERP</span>
        <h1 class="hero__heading animate-on-scroll">ERP empresarial de nueva generación</h1>
        <p class="hero__subtitle animate-on-scroll">Plataforma ERP construida sobre microservicios con arquitectura orientada a aspectos.</p>
      </div>
    </section>

    <!-- Content Section -->
    <section class="content">
      <div class="content__container">
        <div class="content__grid">
          <div class="content__description animate-on-scroll">
            <h2 class="content__title">El futuro del ERP empresarial</h2>
            <p class="content__text">
              1nativoone es la subsidiaria de ARAR que desarrolla un ERP empresarial moderno. A diferencia de los ERP heredados, 1nativoone está construido desde cero con tecnologías actuales para ofrecer flexibilidad, rendimiento y seguridad de clase mundial.
            </p>
            <p class="content__text">
              Cada módulo ha sido diseñado para adaptarse a las necesidades reales de las empresas latinoamericanas, con un enfoque en la experiencia del usuario y la eficiencia operativa.
            </p>
          </div>

          <div class="content__features animate-on-scroll">
            <h3 class="features__title">Características clave</h3>
            <div class="features__grid">
              <div class="features__pill">
                <span class="features__pill-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
                </span>
                <span>Áreas funcionales modulares</span>
              </div>
              <div class="features__pill">
                <span class="features__pill-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="17 1 21 5 17 9"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><polyline points="7 23 3 19 7 15"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
                </span>
                <span>Transacciones transversales</span>
              </div>
              <div class="features__pill">
                <span class="features__pill-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                </span>
                <span>Seguridad y control de acceso avanzado</span>
              </div>
              <div class="features__pill">
                <span class="features__pill-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
                </span>
                <span>Diseño UX/UI innovador</span>
              </div>
              <div class="features__pill">
                <span class="features__pill-icon" aria-hidden="true">
                  <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
                </span>
                <span>Rendimiento y escalabilidad de clase mundial</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Technical Specs Section -->
    <section class="specs">
      <div class="specs__container">
        <h2 class="specs__heading animate-on-scroll">Especificaciones técnicas</h2>
        <div class="specs__grid animate-on-scroll">
          <div class="specs__card">
            <span class="specs__card-label">Plataforma</span>
            <span class="specs__card-value">ASP.NET</span>
          </div>
          <div class="specs__card">
            <span class="specs__card-label">Arquitectura</span>
            <span class="specs__card-value">Microservicios</span>
          </div>
          <div class="specs__card">
            <span class="specs__card-label">Diseño</span>
            <span class="specs__card-value">Orientado a aspectos</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Strategic Narrative -->
    <section class="narrative">
      <div class="narrative__container">
        <div class="narrative__content animate-on-scroll">
          <h2 class="narrative__heading">SAP hoy, ¿1nativoone mañana?</h2>
          <p class="narrative__text">
            En ARAR entendemos que la transformación tecnológica es un viaje, no un salto. Hoy le ayudamos a maximizar su inversión en SAP con nuestro equipo de consultores expertos. Pero cuando su empresa esté lista para el siguiente paso, 1nativoone es la respuesta.
          </p>
          <p class="narrative__text">
            Un ERP moderno, construido con las tecnologías del futuro, diseñado para crecer con su empresa. Sin las limitaciones de los sistemas heredados, con toda la potencia de la arquitectura moderna.
          </p>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  /* =============================================
     HERO
     ============================================= */
  .hero {
    position: relative;
    background: linear-gradient(160deg, var(--color-neutral-950) 0%, var(--color-neutral-900) 60%, var(--color-primary-900) 100%);
    padding: 140px 0 64px;
    text-align: center;
  }

  .hero__container {
    position: relative;
    z-index: 1;
    max-width: 800px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .hero .badge {
    margin-bottom: 20px;
    background-color: rgba(59, 112, 166, 0.2);
    color: #8FB2D6;
  }

  .hero__heading {
    font-size: clamp(1.8rem, 4.5vw, 2.6rem);
    font-weight: 800;
    color: #ffffff;
    line-height: 1.15;
    margin-bottom: 16px;
  }

  .hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.15rem);
    color: #9EADBB;
    line-height: 1.6;
    max-width: 600px;
    margin: 0 auto;
  }

  /* =============================================
     CONTENT
     ============================================= */
  .content {
    padding: 96px 0;
    background-color: var(--color-bg, #ffffff);
  }

  .content__container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .content__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }

  .content__title {
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    font-weight: 700;
    color: var(--color-dark, #1A2332);
    margin-bottom: 20px;
  }

  .content__text {
    font-size: 1rem;
    color: var(--color-text, #3D4F63);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .content__text:last-child {
    margin-bottom: 0;
  }

  .features__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-dark, #1A2332);
    margin-bottom: 24px;
  }

  .features__grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .features__pill {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 18px;
    background-color: var(--color-primary-light, #EDF2F8);
    border-radius: var(--radius, 10px);
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-dark, #1A2332);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .features__pill:hover {
    transform: translateX(4px);
    box-shadow: var(--shadow-sm, 0 1px 2px rgba(15, 20, 25, 0.05));
  }

  .features__pill-icon {
    flex-shrink: 0;
    color: var(--color-primary-900, #1B344F);
  }

  /* =============================================
     SPECS
     ============================================= */
  .specs {
    padding: 80px 0;
    background-color: var(--color-bg-alt, #F6F8FA);
  }

  .specs__container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 24px;
    text-align: center;
  }

  .specs__heading {
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    font-weight: 700;
    color: var(--color-dark, #1A2332);
    margin-bottom: 40px;
  }

  .specs__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    max-width: 800px;
    margin: 0 auto;
  }

  .specs__card {
    background-color: #ffffff;
    border-radius: var(--radius-lg, 16px);
    padding: 32px 24px;
    box-shadow: var(--shadow-sm, 0 1px 2px rgba(15, 20, 25, 0.05));
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .specs__card-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-primary-900, #1B344F);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .specs__card-value {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-dark, #1A2332);
  }

  /* =============================================
     NARRATIVE
     ============================================= */
  .narrative {
    padding: 96px 0;
    background-color: var(--color-bg, #ffffff);
  }

  .narrative__container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .narrative__content {
    max-width: 760px;
    margin: 0 auto;
    text-align: center;
  }

  .narrative__heading {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 800;
    color: var(--color-dark, #1A2332);
    margin-bottom: 20px;
  }

  .narrative__text {
    font-size: 1.05rem;
    color: var(--color-text, #3D4F63);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .narrative__text:last-child {
    margin-bottom: 0;
  }

  /* =============================================
     CTA
     ============================================= */
  .cta {
    background-color: var(--color-bg-alt, #F6F8FA);
    padding: 80px 0;
  }

  .cta__container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .cta__content {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta__heading {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 800;
    color: var(--color-dark, #1A2332);
    margin-bottom: 12px;
  }

  .cta__text {
    font-size: 1.05rem;
    color: var(--color-text, #3D4F63);
    line-height: 1.6;
    margin-bottom: 32px;
  }

  .cta__buttons {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn--nativoone {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 32px;
    font-family: var(--font-family, 'Inter', sans-serif);
    font-size: 0.95rem;
    font-weight: 600;
    color: #ffffff;
    background-color: var(--color-primary-900, #1B344F);
    border: 2px solid var(--color-primary-900, #1B344F);
    border-radius: 9999px;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease, border-color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn--nativoone:hover {
    background-color: var(--color-neutral-900, #1A2332);
    border-color: var(--color-neutral-900, #1A2332);
    color: #ffffff;
    transform: translateY(-1px);
    box-shadow: 0 4px 8px rgba(15, 20, 25, 0.06), 0 12px 32px rgba(15, 20, 25, 0.08);
  }

  .btn--nativoone:active {
    transform: translateY(0);
    box-shadow: none;
  }

  .btn--nativoone-outline {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 14px 32px;
    font-family: var(--font-family, 'Inter', sans-serif);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-primary-900, #1B344F);
    background-color: transparent;
    border: 2px solid var(--color-primary-900, #1B344F);
    border-radius: 9999px;
    text-decoration: none;
    cursor: pointer;
    transition: background-color 0.2s ease, color 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .btn--nativoone-outline:hover {
    background-color: var(--color-primary-900, #1B344F);
    color: #ffffff;
    transform: translateY(-1px);
    box-shadow: 0 4px 8px rgba(15, 20, 25, 0.06), 0 12px 32px rgba(15, 20, 25, 0.08);
  }

  .btn--nativoone-outline:active {
    transform: translateY(0);
    box-shadow: none;
  }

  /* =============================================
     RESPONSIVE
     ============================================= */
  @media (max-width: 1024px) {
    .content__grid {
      gap: 48px;
    }

    .specs__grid {
      gap: 16px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      padding: 120px 0 48px;
    }

    .content {
      padding: 64px 0;
    }

    .content__grid {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .specs {
      padding: 64px 0;
    }

    .specs__grid {
      grid-template-columns: 1fr;
      gap: 16px;
      max-width: 360px;
    }

    .narrative {
      padding: 64px 0;
    }

    .cta {
      padding: 64px 0;
    }

    .cta__buttons {
      flex-direction: column;
      align-items: center;
    }
  }

  @media (max-width: 480px) {
    .hero {
      padding: 108px 0 40px;
    }

    .hero__heading {
      font-size: 1.6rem;
    }

    .content {
      padding: 48px 0;
    }

    .features__pill {
      padding: 12px 14px;
      font-size: 0.88rem;
    }

    .specs {
      padding: 48px 0;
    }

    .specs__card {
      padding: 24px 20px;
    }

    .narrative {
      padding: 48px 0;
    }

    .cta {
      padding: 48px 0;
    }

    .cta__heading {
      font-size: 1.4rem;
    }

    .btn--nativoone,
    .btn--nativoone-outline {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  const animElements = document.querySelectorAll('.animate-on-scroll');

  animElements.forEach((el) => {
    gsap.fromTo(
      el,
      { opacity: 0, y: 30 },
      {
        opacity: 1,
        y: 0,
        duration: 0.8,
        ease: 'power2.out',
        scrollTrigger: {
          trigger: el,
          start: 'top 85%',
          once: true,
        },
      }
    );
  });
</script>
