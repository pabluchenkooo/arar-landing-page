            </svg>
          </a>
          <a
            href="https://www.instagram.com/arar_representaciones"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="footer__social-link"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a
            href="https://www.facebook.com/ARARRepresentaciones"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="footer__social-link"
          >
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Soluciones -->
      <div class="footer__group">
        <h4 class="footer__group-title">Soluciones</h4>
        <ul class="footer__group-list">
          <li><a href={`${base}sap`}>Consultoría SAP</a></li>
          <li><a href={`${base}alquiler`}>Alquiler IT</a></li>
          <li><a href={`${base}ia`}>Automatización IA</a></li>
          <li><a href={`${base}1nativoone`}>1nativoone ERP</a></li>
        </ul>
      </div>

      <!-- Empresa -->
      <div class="footer__group">
        <h4 class="footer__group-title">Empresa</h4>
        <ul class="footer__group-list">
          <li><a href="#">Sobre Nosotros</a></li>
          <li><a href="#">Clientes</a></li>
          <li><a href="#">Blog</a></li>
        </ul>
      </div>

      <!-- Contacto -->
      <div class="footer__group">
        <h4 class="footer__group-title">Contacto</h4>
        <ul class="footer__group-list">
          <li>Calle 125 # 19-89 Oficina 502 Bogotá</li>
          <li><a href="tel:+5716582646">+57 1 658 26 46</a></li>
          <li><a href="mailto:arar@arar.com.co">arar@arar.com.co</a></li>
          <li>Lun–Vie 9:00 AM – 6:00 PM</li>
        </ul>
      </div>

      <!-- Legal -->
      <div class="footer__group">
        <h4 class="footer__group-title">Legal</h4>
        <ul class="footer__group-list">
          <li><a href="#">Política de Privacidad</a></li>
          <li><a href="#">Términos y Condiciones</a></li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="footer__bottom">
      <p>&copy; 2026 ARAR Representaciones. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<!-- WhatsApp floating button -->
<a
  href="https://wa.me/573102961407"
  target="_blank"
  rel="noopener noreferrer"
  class="whatsapp-btn"
  aria-label="Contactar por WhatsApp"
>
  <svg width="28" height="28" viewBox="0 0 24 24" fill="#fff">
    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
  </svg>
</a>

<style>
  /* ───────────────────────────────────────────────
     Footer
     ─────────────────────────────────────────────── */
  .footer {
    background: var(--color-neutral-950, #0F1419);
    padding: 64px 0 32px;
    color: #fff;
  }

  .footer__container {
    max-width: 1160px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .footer__grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr 1fr;
    gap: 40px;
  }

  /* ── Brand column ── */
  .footer__logo {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .footer__tagline {
    margin-top: 12px;
    font-size: 14px;
    line-height: 1.6;
    color: var(--color-neutral-400, #9CA3AF);
    max-width: 280px;
  }

  .footer__social {
    display: flex;
    gap: 12px;
    margin-top: 24px;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-neutral-400, #9CA3AF);
    transition: color 0.2s ease;
    text-decoration: none;
  }

  .footer__social-link:hover {
    color: #fff;
  }

  /* ── Link groups ── */
  .footer__group-title {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 600;
    color: var(--color-neutral-500, #6B7280);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0 0 16px;
  }

  .footer__group-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .footer__group-list li {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--color-neutral-400, #9CA3AF);
    line-height: 2.2;
  }

  .footer__group-list a {
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 400;
    color: var(--color-neutral-400, #9CA3AF);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .footer__group-list a:hover {
    color: #fff;
    text-decoration: none;
  }

  /* ── Bottom bar ── */
  .footer__bottom {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--color-neutral-800, #1F2937);
    text-align: center;
  }

  .footer__bottom p {
    font-size: 13px;
    color: var(--color-neutral-500, #6B7280);
    margin: 0;
  }

  /* ───────────────────────────────────────────────
     WhatsApp floating button
     ─────────────────────────────────────────────── */
  .whatsapp-btn {
    position: fixed;
    bottom: 24px;
    right: 24px;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: #25d366;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 999;
    box-shadow: 0 4px 12px rgba(37, 211, 102, 0.3);
    transition: transform 0.2s ease;
    text-decoration: none;
  }

  .whatsapp-btn:hover {
    transform: scale(1.08);
  }

  /* ───────────────────────────────────────────────
     Responsive
     ─────────────────────────────────────────────── */

  /* Tablet: 2 columns */
  @media (max-width: 992px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
      gap: 36px;
    }

    .footer__brand {
      grid-column: 1 / -1;
    }
  }

  /* Mobile: 1 column, centered */
  @media (max-width: 768px) {
    .footer__grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer__brand {
      grid-column: auto;
    }

    .footer__tagline {
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
    }

    .footer__social {
      justify-content: center;
    }

    .footer__group-list {
      align-items: center;
    }
  }
</style>
