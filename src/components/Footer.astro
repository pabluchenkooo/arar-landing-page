---
const base = import.meta.env.BASE_URL;
---

<footer class="footer">
  <div class="footer__container">
    <div class="footer__grid">
      <!-- Brand column -->
      <div class="footer__brand">
        <a href={base} class="footer__logo">ARAR</a>
        <p class="footer__tagline">
          Grupo tecnológico colombiano con más de 20 años de experiencia
        </p>
        <div class="footer__social">
          <a
            href="https://www.linkedin.com/company/arar-representaciones"
            target="_blank"
            rel="noopener noreferrer"
            aria-label="LinkedIn"
            class="footer__social-link"
          >
