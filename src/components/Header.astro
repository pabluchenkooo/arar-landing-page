---
const navLinks = [
  { label: 'Soluciones', href: '/#soluciones' },
  { label: 'SAP', href: '/sap' },
  { label: 'Alquiler IT', href: '/alquiler' },
  { label: 'IA', href: '/ia' },
  { label: '1nativoone', href: '/1nativoone' },
];
---

<header class="header" id="main-header">
  <div class="header__inner">
    <a href="/" class="header__logo">
      <span class="header__logo-text">ARAR</span>
    </a>

    <nav class="header__nav" id="main-nav">
      <ul class="header__nav-list">
        {navLinks.map((link) => (
          <li>
            <a href={link.href} class="header__nav-link">{link.label}</a>
          </li>
        ))}
      </ul>
      <a href="/#contacto" class="header__cta header__cta--mobile">Contacto</a>
    </nav>

    <a href="/#contacto" class="header__cta header__cta--desktop">Contacto</a>

    <button
      class="header__hamburger"
      id="hamburger-btn"
      aria-label="Abrir menú de navegación"
      aria-expanded="false"
    >
      <span class="header__hamburger-bar"></span>
      <span class="header__hamburger-bar"></span>
      <span class="header__hamburger-bar"></span>
    </button>
  </div>
</header>

<script>
  const header = document.getElementById('main-header')!;
  const hamburger = document.getElementById('hamburger-btn')!;
  const nav = document.getElementById('main-nav')!;

  function handleScroll() {
    if (window.scrollY > 50) {
      header.classList.add('header--scrolled');
    } else {
      header.classList.remove('header--scrolled');
    }
  }

  window.addEventListener('scroll', handleScroll, { passive: true });
  handleScroll();

  hamburger.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('header__hamburger--active');
    nav.classList.toggle('header__nav--open');
    hamburger.setAttribute('aria-expanded', String(isOpen));
    document.body.style.overflow = isOpen ? 'hidden' : '';
  });

  nav.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger.classList.remove('header__hamburger--active');
      nav.classList.remove('header__nav--open');
      hamburger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    });
  });
</script>

<style>
  /* ── Header shell ── */
  .header {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%);
    width: calc(100% - 48px);
    max-width: 1100px;
    height: 56px;
    z-index: 1100;
    background: rgba(255, 255, 255, 0.92);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-radius: 9999px;
    border: 1px solid rgba(255, 255, 255, 0.6);
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.06), 0 1px 4px rgba(0, 0, 0, 0.04);
    transition:
      box-shadow 0.3s ease,
      background 0.3s ease;
  }

  .header--scrolled {
    background: rgba(255, 255, 255, 0.97);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1), 0 1px 4px rgba(0, 0, 0, 0.06);
  }

  /* ── Inner container: logo | nav | cta ── */
  .header__inner {
    max-width: 100%;
    margin: 0;
    padding: 0 24px;
    height: 100%;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
  }

  /* ── Logo ── */
  .header__logo {
    text-decoration: none;
    display: flex;
    align-items: center;
  }

  .header__logo:hover {
    text-decoration: none;
  }

  .header__logo-img {
    height: 32px;
    width: auto;
  }

  .header__logo-text {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 1.3rem;
    font-weight: 600;
    color: var(--color-primary-900, #1B344F);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-left: 8px;
  }

  /* ── Desktop nav (centered) ── */
  .header__nav {
    display: flex;
    justify-content: center;
  }

  .header__nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 28px;
  }

  .header__nav-link {
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: var(--color-dark, #1a2332);
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .header__nav-link:hover {
    color: var(--color-primary, #3b70a6);
  }

  /* ── CTA pill button ── */
  .header__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--color-primary-900, #1B344F);
    color: #fff;
    border-radius: 9999px;
    padding: 10px 24px;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s ease;
    white-space: nowrap;
  }

  .header__cta:hover {
    background: var(--color-neutral-900, #1A2332);
  }

  .header__cta--mobile {
    display: none;
  }

  /* ── Hamburger ── */
  .header__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    padding: 0;
    border: none;
    background: none;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .header__hamburger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--color-dark, #1a2332);
    border-radius: 2px;
    transition:
      transform 0.3s ease,
      opacity 0.3s ease;
    transform-origin: center;
  }

  .header__hamburger--active .header__hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .header__hamburger--active .header__hamburger-bar:nth-child(2) {
    opacity: 0;
  }

  .header__hamburger--active .header__hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .header__inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 20px;
    }

    .header__hamburger {
      display: flex;
    }

    .header__cta--desktop {
      display: none;
    }

    .header__nav {
      position: fixed;
      top: 68px;
      left: 0;
      width: 100%;
      flex-direction: column;
      background: rgba(255, 255, 255, 0.98);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      padding: 16px 20px 24px;
      transform: translateY(-120%);
      opacity: 0;
      transition:
        transform 0.35s ease,
        opacity 0.35s ease;
      box-shadow: 0 12px 32px rgba(0, 0, 0, 0.08);
    }

    .header__nav--open {
      transform: translateY(0);
      opacity: 1;
    }

    .header__nav-list {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .header__nav-link {
      display: block;
      padding: 14px 0;
      font-size: 17px;
      border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    }

    .header__nav-list li:last-child .header__nav-link {
      border-bottom: none;
    }

    .header__cta--mobile {
      display: flex;
      width: 100%;
      margin-top: 16px;
      padding: 14px 24px;
      font-size: 16px;
    }
  }
</style>
